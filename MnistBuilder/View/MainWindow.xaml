<Window 
    x:Class="MNIST.View.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:MNIST.View" 
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:behaviors="clr-namespace:MNIST.Behaviors"
    xmlns:ctrl="clr-namespace:MNIST.Controls"
    DataContext="{StaticResource ViewModel}"
    mc:Ignorable="d"
    WindowState="Maximized"
    Title="MNIST Builder" 
    Height="450" 
    Width="800">
    
    <Window.InputBindings>
        <KeyBinding 
            Key="Left" 
            Command="{Binding  FontController.ChangeFontCommand}">
            <KeyBinding.CommandParameter>
                <sys:Int32>-1</sys:Int32>
            </KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding 
            Key="Right" 
            Command="{Binding FontController.ChangeFontCommand}">
            <KeyBinding.CommandParameter>
                <sys:Int32>1</sys:Int32>
            </KeyBinding.CommandParameter>
        </KeyBinding>
        <KeyBinding 
            Key="Return" 
            Command="{Binding FontController.AddFontToBucketCommand}" 
            CommandParameter="{Binding FontController.SelectedFont, Mode=OneWay}"/>
        <KeyBinding
            Key="Delete"
            Command="{Binding FontController.DeleteFontCommand}"
            CommandParameter="{Binding FontController.SelectedFont}"/>
        <KeyBinding
            Key="Delete"
            Modifiers="Shift"
            Command="{Binding FontController.ClearBucketCommand}"/>
        <KeyBinding
            Key="F5"
            Command="{Binding FontController.GenerateMNISTCommand}"/>
        <KeyBinding
            Key="O"
            Modifiers="Ctrl"
            Command="{StaticResource OpenRepositoryCommand}"/>
        <KeyBinding
            Key="S"
            Modifiers="Ctrl"
            Command="{StaticResource BrowseMnistDirectoryCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="150" />
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
            <RowDefinition Height="80" />
        </Grid.RowDefinitions>
        <!-- Title Bar -->
        <Grid
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Grid.Row="0" 
            Background="{StaticResource AccentBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock 
                Grid.Column="1"
                FontFamily="{StaticResource AliasFont}" 
                FontSize="54" 
                Foreground="{StaticResource DarkForegroundBrush}" 
                TextAlignment="Center"
                FontWeight="Light"
                VerticalAlignment="Center" 
                HorizontalAlignment="Center">
                <Run Text="MNIST bulder"/>
                <Path 
                    Margin="-90,0,0,-15"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Fill="{StaticResource DarkForegroundBrush}" 
                    Data="M9834 4281 c-49 -31 -95 -65 -103 -74 -8 -10 -23 -94 -37 -204 -36 -286 -42 -323 -55 -339 -7 -9 -13 -45 -13 -84 -1 -38 -4 -72 -9 -76 -4 -4 -33 -2 -64 5 -101 22 -103 23 -58 35 l40 12 5 84 c3 47 2 90 -2 96 -5 7 -29 17 -53 23 -28 7 -45 17 -45 26 0 9 -10 15 -25 15 -15 0 -25 -6 -25 -14 0 -17 -22 -26 -61 -26 -34 0 -31 -8 -68 208 -24 138 -29 157 -47 158 -87 4 -84 3 -84 28 0 47 -16 52 -227 65 -109 7 -241 10 -293 6 -106 -7 -830 37 -890 55 -20 6 -66 7 -106 4 l-72 -7 -6 -45 c-3 -24 -6 -69 -6 -98 0 -56 -6 -62 -41 -44 -20 11 -27 60 -9 60 11 0 14 49 4 74 -5 12 -20 16 -59 16 -30 0 -56 -3 -59 -8 -2 -4 -1 -23 3 -42 6 -31 11 -35 42 -38 30 -3 37 -8 45 -35 6 -22 19 -37 43 -47 l34 -15 -7 -125 c-4 -69 -15 -201 -24 -295 l-17 -170 -42 0 c-32 0 -48 -6 -71 -28 -27 -26 -33 -28 -64 -19 -53 15 -71 -3 -63 -64 l6 -49 -118 -97 c-65 -53 -130 -110 -146 -126 l-28 -29 3 -164 3 -164 55 -7 c72 -9 230 -10 305 -3 l60 6 16 -34 c17 -33 17 -33 -17 -65 -28 -27 -41 -32 -82 -32 -54 0 -92 -21 -92 -52 0 -29 -38 -78 -60 -78 -19 0 -37 -39 -32 -67 1 -6 -21 -31 -49 -56 -45 -39 -51 -49 -45 -72 8 -31 -7 -55 -35 -55 -27 0 -49 -28 -49 -64 0 -24 -10 -41 -41 -71 -31 -31 -39 -46 -36 -65 3 -14 -2 -37 -11 -52 -9 -15 -13 -30 -10 -34 4 -3 52 1 108 10 55 9 111 16 123 16 22 0 22 -1 -3 -20 -15 -11 -64 -26 -120 -36 -52 -9 -106 -23 -120 -30 -25 -12 -26 -15 -23 -101 1 -48 -3 -100 -9 -116 -7 -19 -7 -31 0 -40 6 -7 14 -32 18 -55 10 -64 18 -67 145 -54 62 7 115 9 120 6 21 -13 4 -22 -62 -33 -95 -15 -109 -24 -109 -66 0 -40 8 -65 22 -65 6 0 26 -13 45 -30 18 -16 37 -30 42 -30 5 0 11 -13 14 -29 7 -33 52 -56 95 -48 21 4 33 0 46 -15 15 -17 25 -19 58 -14 31 5 45 3 59 -10 14 -12 30 -15 64 -11 40 4 50 1 71 -20 21 -21 31 -24 60 -19 26 5 41 2 59 -12 20 -16 32 -18 67 -12 37 7 44 5 61 -16 17 -22 24 -24 68 -18 43 6 51 4 67 -16 18 -22 21 -23 66 -10 45 12 47 12 71 -14 28 -30 26 -30 69 -12 33 14 34 13 55 -15 24 -32 46 -36 96 -15 33 14 34 14 58 -17 l24 -32 55 18 c69 22 78 21 78 -2 0 -28 26 -44 57 -36 57 15 91 10 117 -18 24 -26 25 -26